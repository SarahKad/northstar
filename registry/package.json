{
  "name": "registry",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "for p in 3000 3001 3002 3004; do lsof -ti :$p | xargs kill -9 2>/dev/null || true; done",
    "dev": "next dev -p 3000",
    "dev:install": "next dev -p 3002",
    "dev:clean": "for p in 3000 3001 3002 3004; do lsof -ti :$p | xargs kill -9 2>/dev/null || true; done; rm -rf .next && next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "registry:generate": "tsx scripts/generate-registry.ts && tsx scripts/generate-start-here.ts",
    "start-here:generate": "tsx scripts/generate-start-here.ts",
    "scaffold:shell": "node scripts/scaffold-app-shell.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^15.3.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-table": "^8.21.3",
    "@types/mdx": "^2.0.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.16.0",
    "next": "^15.3.0",
    "next-themes": "^1.0.0-beta.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@figma/code-connect": "^1.4.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.3.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
